// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  username    String?   @unique
  googleId    String?   @unique
  password    String?
  name        String?
  isSuperuser Boolean   @default(false)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  monitors    Monitor[]
  sites       Site[]
  // Google Analytics OAuth connection (read-only scope)
  googleAccessToken     String?
  googleRefreshToken    String?
  googleTokenExpiresAt  DateTime?
  googleConnectedAt     DateTime?
  googleConnectedEmail  String?
}

model Monitor {
  id              String      @id @default(uuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  url             String
  interval        Int         @default(5) // minutes
  timeout         Int         @default(10) // seconds
  status          MonitorStatus @default(PENDING)
  isActive        Boolean     @default(true)
  lastCheckedAt   DateTime?
  lastStatusCode  Int?
  lastResponseTime Int?       // ms
  uptimePercent   Float       @default(100)
  // SSL / domain
  sslValidFrom     DateTime?
  sslValidUntil    DateTime?
  sslIssuer        String?
  sslDaysLeft      Int?
  sslValid         Boolean?   // false if cert is expired or hostname mismatch
  sslLastCheckedAt DateTime?
  domainResolved      Boolean?   // false on ENOTFOUND / EAI_AGAIN
  domainExpiresAt     DateTime?
  domainRegistrar     String?
  domainDaysLeft      Int?
  domainLastCheckedAt DateTime?
  // Server geolocation (resolved from hostname → IP → geo)
  serverIp            String?
  serverLat           Float?
  serverLng           Float?
  serverCountry       String?
  serverCountryCode   String?
  serverRegion        String?
  serverCity          String?
  serverGeoCheckedAt  DateTime?
  // Last time a DOWN alert was sent. Used to throttle repeat alerts to once per hour while DOWN.
  lastDownAlertAt DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  checks          Check[]
  incidents       Incident[]
  alertContacts   AlertContact[]
}

model Check {
  id           String      @id @default(uuid())
  monitorId    String
  monitor      Monitor     @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  status       CheckStatus
  statusCode   Int?
  responseTime Int?        // ms
  errorMessage String?
  checkedAt    DateTime    @default(now())

  @@index([monitorId, checkedAt])
}

model Incident {
  id          String    @id @default(uuid())
  monitorId   String
  monitor     Monitor   @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  startTime   DateTime  @default(now())
  endTime     DateTime?
  duration    Int?      // seconds
  resolved    Boolean   @default(false)
  errorMessage String?
  createdAt   DateTime  @default(now())
}

model AlertContact {
  id        String   @id @default(uuid())
  monitorId String
  monitor   Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  type      AlertType @default(EMAIL)
  value     String   // email address or webhook URL
  createdAt DateTime @default(now())
}

enum MonitorStatus {
  PENDING
  UP
  DOWN
}

enum CheckStatus {
  UP
  DOWN
}

enum AlertType {
  EMAIL
  SLACK
  WEBHOOK
}

model Site {
  id            String        @id @default(uuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String?
  url           String
  // GA4 property in the form "properties/123456789" — null until the user picks one.
  gaPropertyId  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  seoSnapshot   SeoSnapshot?
}

model SeoSnapshot {
  id         String   @id @default(uuid())
  siteId     String   @unique
  site       Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  fetchedAt  DateTime @default(now())
  fetchOk    Boolean
  fetchError String?
  statusCode Int?
  score      Int?
  issueCount Int?
  details    Json
  updatedAt  DateTime @updatedAt
}
